{
  "name": "backend-fastapi",
  "root": "apps/backend/fastapi",
  "sourceRoot": "apps/backend/fastapi",
  "projectType": "application",
  "implicitDependencies": ["alveslib"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/backend/fastapi",
        "command": "uv run python server.py"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run python -m compileall apps/backend/fastapi"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run ruff check apps/backend/fastapi"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run mypy apps/backend/fastapi"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest apps/backend/fastapi -v"
      }
    }
  }
}
