NAME=myproject
COMPOSE_PROJECT_NAME=$NAME

# Backend
BACKEND_MODE=fastapi
BACKEND_PORT=9812
BACKEND_PUBLIC_URL=http://localhost:9812
WEBAPP_ORIGIN=http://localhost:5173
# Story runtime
# Keep hub mode enabled for one-scene multi-NPC runs.
STORY_WORLD_HUB_MODE=true
# Optional locally; required in deployed environments for stable sessions.
APP_SECRET_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_COOKIE_NAME=athens_session
SESSION_TTL_SECONDS=604800
SESSION_COOKIE_SECURE=false

# Ports
REDIS_PORT=6378
GRAFANA_PORT=3125
LOKI_PORT=3142
JAEGER_UI_PORT=16686
OTEL_HTTP_PORT=4318
OTEL_GRPC_PORT=4317

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
# Optional override. If unset, the backend builds DATABASE_URL from the POSTGRES_* vars above.
# DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<db>

# MongoDB
MONGO_PORT=27017
MONGO_DB=app
MONGO_USER=admin
MONGO_PASSWORD=admin123
MONGO_HOST=localhost

DATABASE_TYPE=postgres

# Redis
REDIS_URL=redis://localhost:${REDIS_PORT}
# Cache toggles (Redis primary, in-memory fallback)
CACHE_USE_REDIS=true
OPENAI_CACHE_ENABLED=true
OPENAI_CACHE_TTL_SECONDS=900
TTS_CACHE_TTL_SECONDS=3600
TTS_MAX_TEXT_CHARS=1400

# OpenTelemetry (Jaeger all-in-one via make lift.telemetry)
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# Optional local overrides for service names
# OTEL_BACKEND_SERVICE_NAME=backend-fastapi
# OTEL_WORKER_SERVICE_NAME=worker
# OTEL_SERVICE_NAME=myproject-backend
# OTEL_SDK_DISABLED=false
LOG_LEVEL=INFO

# Frontend
# Optional override. Leave unset in local dev to use Vite /api proxy default target.
VITE_API_BASE_URL=http://localhost:9812
# Direct BE origin used only for OAuth login initiation (bypasses FE proxy so
# the OAuth CSRF state cookie stays on the BE domain for callback verification).
# In dev: http://localhost:9812. In prod: https://your-backend.up.railway.app
VITE_AUTH_BACKEND_URL=http://localhost:9812
# Used by apps/webapp/server.mjs in deployed FE service to proxy /api/* to backend.
BACKEND_PROXY_TARGET=http://localhost:9812

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9900

# ML
ML_LATEST_WEIGHTS_PATH=/app/models/weights
MLFLOW_TRACKING_URI=http://localhost:5000

# AI / Agents
OPENAI_API_KEY=sk-proj-...
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_IDS=21m00Tcm4TlvDq8ikWAM,AZnzlk1XvdvUeBnXmlld
# Optional: use Bedrock instead of direct OpenAI API
# CLAUDE_CODE_USE_BEDROCK=1
# Optional: use Vertex AI
# CLAUDE_CODE_USE_VERTEX=1
